---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="DevToolsHub | Essential Tools for Developers">
  <div class="mb-12">
    <h2 class="text-3xl font-bold text-white tracking-tight mb-2">Available Tools</h2>
    <p class="text-neutral-400">Essential utilities to boost your productivity.</p>
  </div>

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    <a 
      href="/tools/json-formatter" 
      class="group relative overflow-hidden rounded-xl border border-neutral-800 bg-neutral-900 p-6 transition-all hover:border-blue-500/50 hover:bg-neutral-800/50"
    >
      <div class="mb-4 inline-flex size-10 items-center justify-center rounded-lg bg-blue-500/10 text-blue-500 group-hover:bg-blue-500 group-hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18V12"/><path d="M9 15h6"/></svg>
      </div>
      <h3 class="text-lg font-semibold text-white mb-2">JSON Formatter</h3>
      <p class="text-sm text-neutral-400">Beautify and validate your JSON data with custom indentation.</p>
    </a>
  </div>
</BaseLayout>